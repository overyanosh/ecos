[Unit]
Description=ecos — Mount root filesystem read-only
DefaultDependencies=no
After=local-fs.target
Before=sysinit.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/ecos-lock-writes.sh mount
ExecStop=/usr/local/bin/ecos-lock-writes.sh unmount

[Install]
WantedBy=multi-user.target